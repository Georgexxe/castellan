# Castellan — environment template. Copy to `.env` and fill in. `.env` is gitignored.

# --- Band connection -------------------------------------------------------
# From the Band dashboard / Setup page (app.band.ai). The installed SDK module is
# `band`, so the BAND_* pair is what the code reads. If unset, the SDK defaults to
# the hosted Band (wss://app.band.ai/... and https://app.band.ai).
BAND_WS_URL=
BAND_REST_URL=

# --- Model providers -------------------------------------------------------
# Scanner (M1) — Featherless.
FEATHERLESS_API_KEY=
# Optional: override the Scanner's open-source model id (default in code:
# Qwen/Qwen2.5-7B-Instruct — open, ungated). Must be a valid Featherless catalog id.
FEATHERLESS_MODEL=

# Controller (M2) + Risk (M3) — Anthropic via LangGraph. ANTHROPIC_API_KEY required for both.
ANTHROPIC_API_KEY=
# Optional model overrides (defaults in code). Controller: claude-sonnet-4-6; Risk: claude-opus-4-8
# (distinct model for the gate). Confirm both ids are enabled on your Anthropic key.
CONTROLLER_MODEL=
RISK_MODEL=
